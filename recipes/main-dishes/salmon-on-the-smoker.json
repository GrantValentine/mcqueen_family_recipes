{
  "title": "Salmon on the Smoker",
  "ingredients": [
    "1½ to 2 pounds salmon, rinsed and patted dry",
    "3 tablespoons butter, softened",
    "1 medium shallot, chopped small",
    "1 tablespoon fresh chives, chopped small",
    "1 tablespoon fresh parsley, chopped",
    "2 cloves garlic, minced or pressed",
    "½ teaspoon sea salt",
    "½ teaspoon Old Bay seasoning",
    "½ teaspoon ground black pepper",
    "fresh lemon wedges (optional, for serving)"
  ],
  "instructions": [
    "Mix softened butter with herbs, shallot, and garlic.",
    "Place salmon on baking sheet.",
    "Cover salmon with butter mixture.",
    "Place on Traeger grill set at 275°F for about 35 minutes.",
    "Remove salmon and tent with foil.",
    "Let rest for 5 minutes.",
    "Serve with lemon wedges."
  ],
  "notes": [
    "Frank loves this salmon."
  ],
