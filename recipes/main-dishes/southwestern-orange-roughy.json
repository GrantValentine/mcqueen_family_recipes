{
  "title": "Southwestern Orange Roughy",
  "ingredients": [
    "2 pounds orange roughy fillets",
    "¾ cup sour cream",
    "½ cup cream cheese, softened",
    "1 cup shredded white Cheddar cheese",
    "1 tablespoon minced onion",
    "1 tablespoon fresh lemon juice",
    "½ teaspoon garlic salt",
    "½ teaspoon cayenne pepper (to taste)",
    "1 (4-ounce) can diced green chiles",
    "Fresh cilantro, minced",
    "Paprika"
  ],
  "instructions": [
    "Preheat oven to 375°F.",
    "Arrange fish fillets in a greased baking dish.",
    "In a bowl, blend sour cream, cream cheese, Cheddar, onion, lemon juice, garlic salt, cayenne, chiles, and cilantro until smooth.",
    "Spread mixture evenly over fish.",
    "Sprinkle lightly with paprika.",
    "Bake until fish flakes easily and topping is lightly golden."
  ],
