{
  "title": "Café Rio Salad Dressing",
  "ingredients": [
    "1 pkg. Ranch dressing mix",
    "4 tomatillos, papery skin removed, rough chopped",
    "1/2 cup cottage cheese",
    "1/2 cup sour cream",
    "1/2 cup buttermilk",
    "1 cup (or more) cilantro, rough chopped",
    "3 cloves garlic",
    "1/8 tsp cayenne pepper",
    "1-2 tsp green Tabasco sauce",
    "juice from 1-2 limes"
  ],
  "instructions": [
    "Place all ingredients in a blender and blend until smooth."
  ],
