# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit it.

# Supabase project credentials (both are public by design — safe to expose)
SUPABASE_URL=https://your-project.supabase.co/
SUPABASE_ANON_KEY=your-anon-key-here

# Admin email — must match the user created in Supabase Auth dashboard
ADMIN_EMAIL=your-admin-email@example.com

# Netlify build hook URL (Site settings → Build & deploy → Build hooks → Add hook)
# When the admin clicks "Publish Changes", this URL is POSTed to trigger a rebuild.
NETLIFY_BUILD_HOOK=https://api.netlify.com/build_hooks/your-hook-id-here

# Only needed locally when running the one-time migration script:
# python scripts/migrate_to_supabase.py
ADMIN_PASSWORD=
